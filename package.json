{
  "name": "google-search-console-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Google Search Console with Supabase Auth and MCPize-ready HTTP transport.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@supabase/supabase-js": "^2.49.8",
    "express": "^5.1.0",
    "googleapis": "^144.0.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
